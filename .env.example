NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/smart_logistics

# Maximum number of graphs to retain; older graphs are evicted on insert
MAX_GRAPHS=5

# Auth: leave empty to disable the API key guard. When set, clients must send
# the value as the `x-api-key` header on all endpoints except /docs and /healthz.
API_KEY=

CORS_ORIGIN=*

# Per-IP throttling — default 5 requests / second / IP (DoS protection)
RATE_LIMIT_TTL_MS=1000
RATE_LIMIT_MAX=5

# Reject upload bodies larger than this (bytes)
BODY_LIMIT_BYTES=1048576

# Hard wall-clock cap on a single optimize() call
DIJKSTRA_TIMEOUT_MS=500
